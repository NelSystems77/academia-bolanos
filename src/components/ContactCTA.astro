---
import { useTranslations, type Lang } from "@/i18n/ui";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const waURL = `https://wa.me/50689215848?text=${encodeURIComponent(t("wa.message"))}`;
---

<section id="contact" class="contact-cta" aria-labelledby="contact-title">
  <div class="container-page">
    <div class="contact-cta__inner">
      <div class="contact-cta__glow" aria-hidden="true"></div>

      <div class="contact-cta__text">
        <span class="section-label" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.09 6.09l1.28-.78a2 2 0 0 1 2.11.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17z"/>
          </svg>
          {lang === "es" ? "Contáctanos" : "Contact us"}
        </span>
        <h2 id="contact-title" class="contact-cta__title">
          {lang === "es"
            ? "¿Listo para comenzar tu camino musical?"
            : "Ready to start your musical journey?"}
        </h2>
        <p class="contact-cta__subtitle">
          {lang === "es"
            ? "Escríbenos directamente por WhatsApp. Respondemos rápido y sin compromisos. Primera clase gratis."
            : "Write us directly on WhatsApp. We respond quickly and with no commitment. First class free."}
        </p>
      </div>

      <div class="contact-cta__actions">
        <a
          href={waURL}
          class="contact-cta__btn contact-cta__btn--primary"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t("wa.button")}
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {t("wa.button")}
        </a>

        <div class="contact-cta__info">
          <div class="contact-cta__info-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.09 6.09l1.28-.78a2 2 0 0 1 2.11.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17z"/>
            </svg>
            <span>+506 8921-5848</span>
          </div>
          <div class="contact-cta__info-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/>
            </svg>
            <span>Costa Rica</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-cta {
    padding-block: 5rem 6rem;
    background: var(--color-dark-2);
    position: relative;
  }

  .contact-cta::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,71,171,0.4), transparent);
  }

  .contact-cta__inner {
    position: relative;
    background: var(--color-surface);
    border: 1px solid rgba(0, 71, 171, 0.3);
    border-radius: var(--radius-xl);
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .contact-cta__inner {
      flex-direction: row;
      text-align: left;
      padding: 3rem 3.5rem;
      justify-content: space-between;
    }
  }

  .contact-cta__glow {
    position: absolute;
    top: 50%;
    left: 30%;
    transform: translate(-50%, -50%);
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(0,71,171,0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .contact-cta__text {
    position: relative;
    z-index: 1;
    flex: 1;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.875rem;
  }

  .contact-cta__title {
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.875rem;
    max-width: 540px;
  }

  .contact-cta__subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 480px;
  }

  .contact-cta__actions {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .contact-cta__actions { align-items: flex-end; }
  }

  .contact-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 2rem;
    border-radius: 9999px;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    transition: all var(--transition-base);
    white-space: nowrap;
  }

  .contact-cta__btn--primary {
    background: #25D366;
    color: #fff;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
  }

  .contact-cta__btn--primary:hover {
    background: #20bb5b;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(37, 211, 102, 0.5);
  }

  .contact-cta__info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  @media (min-width: 768px) {
    .contact-cta__info { align-items: flex-end; }
  }

  .contact-cta__info-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .contact-cta__info-item svg { color: var(--color-accent); }
</style>
