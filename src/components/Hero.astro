---
import { useTranslations, type Lang } from "@/i18n/ui";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const waURL = `https://wa.me/50689215848?text=${encodeURIComponent(t("wa.message"))}`;
const base = "/academia-bolanos";
---

<section id="hero" class="hero" aria-label={lang === "es" ? "Bienvenida" : "Welcome"}>
  <!-- Background decoration -->
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__blob hero__blob--1"></div>
    <div class="hero__blob hero__blob--2"></div>
    <div class="hero__grid"></div>
  </div>

  <div class="container-page hero__content">
    <!-- Left: Text -->
    <div class="hero__text">
      <span class="hero__badge" role="text">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        {t("hero.badge")}
      </span>

      <h1 class="hero__headline">
        <span class="hero__headline-line">{t("hero.headline").split(",")[0]},</span>
        <span class="hero__headline-line text-gradient">
          {t("hero.headline").split(",").slice(1).join(",").trim()}
        </span>
      </h1>

      <p class="hero__subheadline">{t("hero.subheadline")}</p>

      <div class="hero__ctas">
        <a
          href={waURL}
          class="hero__cta hero__cta--primary"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t("hero.cta.primary")}
        >
          <!-- WhatsApp icon -->
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {t("hero.cta.primary")}
        </a>
        <a
          href={`${base}/#services`}
          class="hero__cta hero__cta--secondary"
          aria-label={t("hero.cta.secondary")}
        >
          {t("hero.cta.secondary")}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <div class="hero__stats" role="list" aria-label={lang === "es" ? "Estadísticas" : "Statistics"}>
        <div class="hero__stat" role="listitem">
          <span class="hero__stat-number">200+</span>
          <span class="hero__stat-label">{t("hero.stat.students")}</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat" role="listitem">
          <span class="hero__stat-number">10+</span>
          <span class="hero__stat-label">{t("hero.stat.years")}</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat" role="listitem">
          <span class="hero__stat-number">98%</span>
          <span class="hero__stat-label">{t("hero.stat.satisfaction")}</span>
        </div>
      </div>
    </div>

    <!-- Right: Visual -->
    <div class="hero__visual" aria-hidden="true">
      <div class="hero__card-stack">
        <div class="hero__card hero__card--main">
          <div class="hero__card-icon">🎸</div>
          <div class="hero__card-label">{lang === "es" ? "Guitarra" : "Guitar"}</div>
        </div>
        <div class="hero__card hero__card--tl">
          <div class="hero__card-icon">🎵</div>
          <div class="hero__card-label">{lang === "es" ? "Canto" : "Singing"}</div>
        </div>
        <div class="hero__card hero__card--br">
          <div class="hero__card-icon">🌍</div>
          <div class="hero__card-label">{lang === "es" ? "Idiomas" : "Languages"}</div>
        </div>
        <div class="hero__card hero__card--tr">
          <div class="hero__card-icon">🎶</div>
          <div class="hero__card-label">Ukelele</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 4.5rem;
    overflow: hidden;
    background: var(--color-dark);
  }

  /* Background */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
  }

  .hero__blob--1 {
    width: 55vw;
    height: 55vw;
    background: radial-gradient(circle, #0047AB 0%, transparent 70%);
    top: -15%;
    right: -20%;
    animation: float 8s ease-in-out infinite;
  }

  .hero__blob--2 {
    width: 40vw;
    height: 40vw;
    background: radial-gradient(circle, #00BFFF 0%, transparent 70%);
    bottom: -10%;
    left: -10%;
    opacity: 0.15;
    animation: float 10s ease-in-out infinite reverse;
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-block: 4rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero__content {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      padding-block: 6rem;
    }
  }

  /* Badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    background: rgba(0, 71, 171, 0.2);
    border: 1px solid rgba(0, 71, 171, 0.4);
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    animation: fadeIn 0.6s ease-out forwards;
  }

  .hero__badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  /* Headline */
  .hero__headline {
    font-size: clamp(2.25rem, 5vw + 1rem, 4.5rem);
    font-weight: 900;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    animation: slideUp 0.6s ease-out 0.1s both;
  }

  .hero__headline-line {
    display: block;
  }

  /* Subheadline */
  .hero__subheadline {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 540px;
    margin-bottom: 2rem;
    animation: slideUp 0.6s ease-out 0.2s both;
  }

  /* CTAs */
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 2.5rem;
    animation: slideUp 0.6s ease-out 0.3s both;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8125rem 1.625rem;
    border-radius: 9999px;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
    white-space: nowrap;
  }

  .hero__cta--primary {
    background: #25D366;
    color: #fff;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.35);
  }

  .hero__cta--primary:hover {
    background: #20bb5b;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(37, 211, 102, 0.45);
  }

  .hero__cta--secondary {
    background: rgba(255,255,255,0.07);
    color: var(--color-text);
    border: 1px solid rgba(255,255,255,0.12);
  }

  .hero__cta--secondary:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.2);
    transform: translateY(-2px);
  }

  /* Stats */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    animation: slideUp 0.6s ease-out 0.4s both;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .hero__stat-number {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 800;
    color: var(--color-text);
    line-height: 1;
  }

  .hero__stat-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .hero__stat-divider {
    width: 1px;
    height: 2.5rem;
    background: rgba(255,255,255,0.1);
  }

  /* Visual (floating cards) */
  .hero__visual {
    display: none;
    position: relative;
    height: 420px;
    animation: fadeIn 0.8s ease-out 0.5s both;
  }

  @media (min-width: 1024px) {
    .hero__visual { display: block; }
  }

  .hero__card-stack {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero__card {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.25rem 1.5rem;
    background: rgba(20, 27, 45, 0.85);
    border: 1px solid rgba(0, 71, 171, 0.3);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(12px);
    box-shadow: var(--shadow-card);
    transition: transform var(--transition-slow);
  }

  .hero__card-icon  { font-size: 2.5rem; line-height: 1; }
  .hero__card-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .hero__card--main {
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    padding: 2rem 2.5rem;
    background: rgba(0, 71, 171, 0.2);
    border-color: rgba(0, 71, 171, 0.5);
    box-shadow: var(--shadow-glow);
    animation: float 5s ease-in-out infinite;
  }

  .hero__card--main .hero__card-icon { font-size: 4rem; }
  .hero__card--main .hero__card-label { font-size: 1rem; color: var(--color-text); }

  .hero__card--tl {
    top: 8%; left: 5%;
    animation: float 6s ease-in-out infinite 1s;
  }

  .hero__card--br {
    bottom: 8%; right: 5%;
    animation: float 7s ease-in-out infinite 0.5s;
  }

  .hero__card--tr {
    top: 8%; right: 5%;
    animation: float 5.5s ease-in-out infinite 1.5s;
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    justify-content: center;
    opacity: 0.4;
  }

  .hero__scroll-line {
    width: 1px;
    height: 3rem;
    background: linear-gradient(to bottom, transparent, var(--color-accent));
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }
</style>
