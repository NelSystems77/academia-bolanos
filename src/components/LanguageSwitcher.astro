---
import { languages, type Lang } from "@/i18n/ui";

export interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");

function getAltPath(currentLang: Lang, path: string): { lang: Lang; href: string } {
  if (currentLang === "es") {
    const clean = path === "/" || path === "" ? "" : path;
    return { lang: "en", href: `${BASE}/en${clean}` };
  }
  const stripped = path.replace(/^\/en/, "") || "/";
  return { lang: "es", href: `${BASE}${stripped}` };
}

const alt = getAltPath(lang, currentPath);
---

<div class="lang-switcher" role="navigation" aria-label={lang === "es" ? "Cambiar idioma" : "Change language"}>
  {
    (Object.keys(languages) as Lang[]).map((l) => (
      <a
        href={l === alt.lang ? alt.href : "#"}
        class:list={["lang-btn", { active: l === lang }]}
        aria-current={l === lang ? "true" : undefined}
        hreflang={l}
        aria-label={`${languages[l]} — ${l === lang ? (lang === "es" ? "Idioma actual" : "Current language") : (lang === "es" ? "Cambiar a " + languages[l] : "Switch to " + languages[l])}`}
      >
        {l.toUpperCase()}
      </a>
    ))
  }
</div>

<style>
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    padding: 0.2rem;
  }

  .lang-btn {
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    transition: all 200ms ease;
    text-decoration: none;
  }

  .lang-btn:hover:not(.active) {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.08);
  }

  .lang-btn.active {
    background: var(--color-primary);
    color: #fff;
    pointer-events: none;
  }
</style>
