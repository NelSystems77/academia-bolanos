---
import { useTranslations, type Lang } from "@/i18n/ui";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

interface Promo {
  id: string;
  emoji: string;
  title: { es: string; en: string };
  desc: { es: string; en: string };
  discount?: string;
  active: boolean;
}

const promotions: Promo[] = [
  {
    id: "first-class",
    emoji: "🎁",
    title: { es: "Primera clase gratis", en: "First class free" },
    desc: {
      es: "Prueba cualquier servicio sin compromiso. Tu primera clase es completamente gratis.",
      en: "Try any service without commitment. Your first class is completely free.",
    },
    discount: "100%",
    active: true,
  },
  {
    id: "pack-month",
    emoji: "📅",
    title: { es: "Pack mensual — 4 clases", en: "Monthly pack — 4 classes" },
    desc: {
      es: "Inscríbete al plan mensual y ahorra un 15% respecto a las clases individuales.",
      en: "Sign up for the monthly plan and save 15% compared to individual classes.",
    },
    discount: "15% OFF",
    active: true,
  },
  {
    id: "referral",
    emoji: "🤝",
    title: { es: "Trae un amigo", en: "Bring a friend" },
    desc: {
      es: "Refiere a un amigo y ambos obtienen una clase gratis en cualquier servicio.",
      en: "Refer a friend and you both get a free class in any service.",
    },
    active: true,
  },
];

const activePromos = promotions.filter((p) => p.active);
const waBaseMsg = lang === "es"
  ? "Hola! Me interesa saber más sobre las promociones de Academia Bolaños."
  : "Hello! I'm interested in learning more about Academia Bolaños promotions.";
const waURL = `https://wa.me/50689215848?text=${encodeURIComponent(waBaseMsg)}`;
---

<section id="promotions" class="promotions" aria-labelledby="promo-title">
  <div class="container-page">
    <header class="section-header">
      <span class="section-label" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        {lang === "es" ? "Promociones" : "Promotions"}
      </span>
      <h2 id="promo-title" class="section-title">{t("promo.title")}</h2>
      <p class="section-subtitle">{t("promo.subtitle")}</p>
    </header>

    <div class="promotions__grid" role="list" aria-label={t("promo.title")}>
      {activePromos.map((promo) => (
        <article class="promo-card" role="listitem">
          <div class="promo-card__top">
            <span class="promo-card__emoji" aria-hidden="true">{promo.emoji}</span>
            {promo.discount && (
              <span class="promo-card__badge" aria-label={`${lang === "es" ? "Descuento" : "Discount"}: ${promo.discount}`}>
                {promo.discount}
              </span>
            )}
            {!promo.discount && (
              <span class="promo-card__badge promo-card__badge--accent" aria-label={t("promo.badge")}>
                {t("promo.badge")}
              </span>
            )}
          </div>
          <h3 class="promo-card__title">{promo.title[lang]}</h3>
          <p class="promo-card__desc">{promo.desc[lang]}</p>
          <a
            href={waURL}
            class="promo-card__cta"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t("promo.cta")} — ${promo.title[lang]}`}
          >
            {t("promo.cta")}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .promotions {
    padding-block: 5rem 6rem;
    background: var(--color-dark);
    position: relative;
    overflow: hidden;
  }

  .promotions::before {
    content: "";
    position: absolute;
    top: 40%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0,71,171,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.875rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 0.875rem;
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    max-width: 540px;
    margin-inline: auto;
    line-height: 1.7;
  }

  .promotions__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .promotions__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .promotions__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .promo-card {
    background: var(--color-surface);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    position: relative;
    overflow: hidden;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .promo-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  }

  .promo-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .promo-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .promo-card__emoji { font-size: 2rem; line-height: 1; }

  .promo-card__badge {
    padding: 0.25rem 0.625rem;
    background: rgba(0, 71, 171, 0.25);
    border: 1px solid rgba(0, 71, 171, 0.4);
    color: var(--color-accent);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .promo-card__badge--accent {
    background: rgba(0, 191, 255, 0.15);
    border-color: rgba(0, 191, 255, 0.35);
    color: var(--color-accent);
  }

  .promo-card__title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .promo-card__desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    flex: 1;
  }

  .promo-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: auto;
    transition: gap var(--transition-base), color var(--transition-base);
  }

  .promo-card__cta:hover {
    gap: 0.625rem;
    color: #fff;
  }
</style>
